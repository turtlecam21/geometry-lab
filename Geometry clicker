<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Geometry Clicker</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #07080f;
    --panel: #0d1020;
    --border: #1a2040;
    --neon-blue: #00d4ff;
    --neon-purple: #b040ff;
    --neon-green: #00ff9d;
    --neon-gold: #ffd700;
    --text: #c8d8ff;
    --dim: #4a5580;
  }

  body {
    font-family: 'Share Tech Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ══════════════════════════════════════
     HOME SCREEN
  ══════════════════════════════════════ */
  #home-screen {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    gap: 0;
  }

  /* Subtle radial glow behind home circle */
  #home-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, rgba(80,0,200,0.18) 0%, transparent 70%),
      linear-gradient(rgba(0,212,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.025) 1px, transparent 1px);
    background-size: auto, 40px 40px, 40px 40px;
    pointer-events: none;
  }

  .home-logo {
    position: relative;
    width: 160px;
    height: 160px;
    margin-bottom: 32px;
  }

  .home-logo-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(0,212,255,0.2);
    animation: ring-pulse 3s ease-in-out infinite;
  }
  .home-logo-ring:nth-child(1) { inset: -16px; animation-delay: 0s; }
  .home-logo-ring:nth-child(2) { inset: -32px; animation-delay: 1s; }
  .home-logo-ring:nth-child(3) { inset: -48px; animation-delay: 2s; }

  .home-logo-circle {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 35%, #4090ff, #7020ff 60%, #0a0030);
    box-shadow:
      0 0 50px rgba(80,100,255,0.7),
      0 0 100px rgba(100,0,255,0.35),
      inset 0 0 40px rgba(0,200,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .home-logo-circle::before {
    content: '';
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.22) 0%, transparent 60%);
  }

  .home-geo {
    position: absolute;
    width: 60%;
    height: 60%;
    border: 1px solid rgba(0,220,255,0.25);
    border-radius: 50%;
    animation: geo-spin 8s linear infinite;
  }
  .home-geo::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid rgba(180,100,255,0.35);
    border-radius: 50%;
    animation: geo-spin 5s linear infinite reverse;
  }

  .home-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 6vw, 3.2rem);
    color: var(--neon-blue);
    text-shadow: 0 0 20px var(--neon-blue), 0 0 60px rgba(0,212,255,0.3);
    letter-spacing: 4px;
    text-align: center;
    line-height: 1.1;
    margin-bottom: 8px;
    animation: title-glow 2.5s ease-in-out infinite;
  }

  @keyframes title-glow {
    0%, 100% { text-shadow: 0 0 20px var(--neon-blue), 0 0 60px rgba(0,212,255,0.3); }
    50%       { text-shadow: 0 0 30px var(--neon-blue), 0 0 90px rgba(0,212,255,0.5); }
  }

  .home-subtitle {
    font-size: 0.75rem;
    color: var(--dim);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 48px;
  }

  .home-buttons {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    width: 260px;
  }

  .home-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 2px;
    width: 100%;
    padding: 14px 24px;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }

  .home-btn-primary {
    background: linear-gradient(135deg, #0050cc, #7020ff);
    color: #fff;
    box-shadow: 0 0 20px rgba(80,100,255,0.5);
  }
  .home-btn-primary:hover {
    box-shadow: 0 0 35px rgba(80,100,255,0.8);
    transform: translateY(-2px) scale(1.02);
  }

  .home-btn-secondary {
    background: transparent;
    color: var(--neon-purple);
    border: 1px solid var(--neon-purple);
    box-shadow: 0 0 10px rgba(176,64,255,0.2);
  }
  .home-btn-secondary:hover {
    background: rgba(176,64,255,0.1);
    box-shadow: 0 0 20px rgba(176,64,255,0.4);
    transform: translateY(-2px);
  }

  .home-btn-danger {
    background: transparent;
    color: #ff4466;
    border: 1px solid #ff4466;
    font-size: 0.7rem;
  }
  .home-btn-danger:hover {
    background: rgba(255,68,102,0.1);
    box-shadow: 0 0 14px rgba(255,68,102,0.3);
  }

  .home-save-info {
    margin-top: 20px;
    font-size: 0.65rem;
    color: var(--dim);
    letter-spacing: 1px;
    text-align: center;
    line-height: 1.8;
  }
  .home-save-info span { color: var(--neon-green); }

  /* hide/show screens */
  #home-screen.hidden { display: none; }
  #game-wrapper { display: none; flex-direction: column; flex: 1; overflow: hidden; }
  #game-wrapper.visible { display: flex; }

  /* ══════════════════════════════════════
     TOP BAR
  ══════════════════════════════════════ */
  #topbar {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 24px;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    gap: 16px;
    flex-wrap: wrap;
  }

  .title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--neon-blue);
    text-shadow: 0 0 10px var(--neon-blue);
    letter-spacing: 2px;
    white-space: nowrap;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .title:hover { opacity: 0.7; }

  .stats {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-label {
    font-size: 0.62rem;
    color: var(--dim);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .stat-value {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--neon-green);
    text-shadow: 0 0 8px var(--neon-green);
    transition: transform 0.1s;
  }

  .stat-value.bump { transform: scale(1.3); }

  .top-actions { display: flex; gap: 8px; }

  .btn-small {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--dim);
    color: var(--dim);
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
    border-radius: 3px;
  }
  .btn-small:hover { border-color: var(--neon-blue); color: var(--neon-blue); box-shadow: 0 0 8px rgba(0,212,255,0.3); }
  .btn-small.music-on { border-color: var(--neon-purple); color: var(--neon-purple); }

  /* ══════════════════════════════════════
     MAIN LAYOUT
  ══════════════════════════════════════ */
  #main {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    overflow: hidden;
  }

  /* GAME AREA */
  #game-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 20px;
  }

  /* CIRCLE CONTAINER */
  #circle-container {
    position: relative;
    width: 280px;
    height: 280px;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(0,212,255,0.15);
    animation: ring-pulse 3s ease-in-out infinite;
  }
  .ring-1 { inset: -20px; animation-delay: 0s; }
  .ring-2 { inset: -40px; animation-delay: 1s; }
  .ring-3 { inset: -60px; animation-delay: 2s; }

  @keyframes ring-pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.02); }
  }

  #main-circle {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 35%, #4090ff, #7020ff 60%, #0a0030);
    box-shadow:
      0 0 40px rgba(80,100,255,0.6),
      0 0 80px rgba(100,0,255,0.3),
      inset 0 0 40px rgba(0,200,255,0.1);
    cursor: pointer;
    user-select: none;
    transition: transform 0.08s ease, box-shadow 0.08s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #main-circle::before {
    content: '';
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, rgba(255,255,255,0.25) 0%, transparent 60%);
    pointer-events: none;
  }

  #main-circle .geo {
    position: absolute;
    width: 60%;
    height: 60%;
    border: 1px solid rgba(0,220,255,0.2);
    border-radius: 50%;
    animation: geo-spin 8s linear infinite;
  }
  #main-circle .geo::before {
    content: '';
    position: absolute;
    inset: 15%;
    border: 1px solid rgba(180,100,255,0.3);
    border-radius: 50%;
    animation: geo-spin 5s linear infinite reverse;
  }

  @keyframes geo-spin { to { transform: rotate(360deg); } }

  #main-circle:active, #main-circle.clicked {
    transform: scale(0.92);
    box-shadow:
      0 0 60px rgba(0,212,255,0.9),
      0 0 120px rgba(100,0,255,0.5),
      inset 0 0 50px rgba(0,200,255,0.2);
  }

  .particle {
    position: absolute;
    pointer-events: none;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--neon-blue);
    text-shadow: 0 0 8px currentColor;
    z-index: 100;
    animation: particle-fly 0.9s ease-out forwards;
  }

  @keyframes particle-fly {
    0%   { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-70px) scale(0.5); }
  }

  /* SIDE PANEL */
  #side-panel {
    width: 300px;
    min-width: 240px;
    background: var(--panel);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .panel-header {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    color: var(--neon-purple);
    text-shadow: 0 0 8px var(--neon-purple);
    letter-spacing: 2px;
  }

  #upgrades-list {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #upgrades-list::-webkit-scrollbar { width: 4px; }
  #upgrades-list::-webkit-scrollbar-track { background: transparent; }
  #upgrades-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .upgrade-card {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 10px 12px;
    background: rgba(255,255,255,0.02);
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .upgrade-card.affordable {
    border-color: rgba(0,212,255,0.4);
    background: rgba(0,212,255,0.04);
    box-shadow: 0 0 12px rgba(0,212,255,0.1);
  }

  .upgrade-card.affordable::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(0,212,255,0.05), transparent);
    animation: shimmer 2s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .upgrade-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
  }

  .upgrade-badge {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    width: 20px;
    height: 20px;
    border-radius: 3px;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--neon-purple);
    flex-shrink: 0;
    margin-right: 8px;
  }

  .upgrade-name {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text);
    flex: 1;
  }

  .upgrade-count {
    font-size: 0.65rem;
    color: var(--neon-gold);
    background: rgba(255,215,0,0.1);
    border: 1px solid rgba(255,215,0,0.2);
    border-radius: 10px;
    padding: 1px 7px;
    font-family: 'Orbitron', sans-serif;
  }

  .upgrade-effect {
    font-size: 0.7rem;
    color: var(--neon-green);
    text-shadow: 0 0 6px rgba(0,255,157,0.4);
    margin-bottom: 8px;
  }

  .upgrade-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .upgrade-cost { font-size: 0.72rem; color: var(--dim); }
  .upgrade-cost.can-afford { color: var(--neon-gold); text-shadow: 0 0 6px rgba(255,215,0,0.4); }

  .buy-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 5px 14px;
    background: transparent;
    border: 1px solid var(--dim);
    color: var(--dim);
    cursor: not-allowed;
    letter-spacing: 1px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .buy-btn.enabled {
    border-color: var(--neon-blue);
    color: var(--neon-blue);
    cursor: pointer;
    box-shadow: 0 0 8px rgba(0,212,255,0.2);
  }
  .buy-btn.enabled:hover {
    background: rgba(0,212,255,0.15);
    box-shadow: 0 0 16px rgba(0,212,255,0.4);
    transform: translateY(-1px);
  }
  .buy-btn.enabled:active { transform: scale(0.95); }

  .upgrade-card.just-bought { animation: buy-flash 0.4s ease; }
  @keyframes buy-flash {
    0%   { background: rgba(0,212,255,0.2); border-color: var(--neon-blue); }
    100% { }
  }

  #float-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 50;
  }

  @media (max-width: 640px) {
    #side-panel { width: 200px; min-width: 180px; }
    #circle-container { width: 200px; height: 200px; }
    .ring-2, .ring-3 { display: none; }
    .title { font-size: 0.85rem; }
  }
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     HOME SCREEN
══════════════════════════════════════ -->
<div id="home-screen">
  <div class="home-logo">
    <div class="home-logo-ring"></div>
    <div class="home-logo-ring"></div>
    <div class="home-logo-ring"></div>
    <div class="home-logo-circle">
      <div class="home-geo"></div>
    </div>
  </div>

  <div class="home-title">GEOMETRY<br>CLICKER</div>
  <div class="home-subtitle">◈ Geometry Lab ◈</div>

  <div class="home-buttons">
    <button class="home-btn home-btn-primary" onclick="startGame()">▶ PLAY</button>
    <button class="home-btn home-btn-secondary" id="continue-btn" onclick="continueGame()" style="display:none">◈ CONTINUE</button>
    <button class="home-btn home-btn-danger" id="new-game-btn" onclick="newGame()" style="display:none">↺ NEW GAME</button>
  </div>

  <div class="home-save-info" id="save-info"></div>
</div>

<!-- ══════════════════════════════════════
     GAME WRAPPER
══════════════════════════════════════ -->
<div id="game-wrapper">

  <!-- TOP BAR -->
  <div id="topbar">
    <div class="title" onclick="goHome()" title="Back to Home">◈ GEOMETRY CLICKER</div>
    <div class="stats">
      <div class="stat">
        <span class="stat-label">TOTAL CLICKS</span>
        <span class="stat-value" id="stat-clicks">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">PER SECOND</span>
        <span class="stat-value" id="stat-cps">0</span>
      </div>
      <div class="stat">
        <span class="stat-label">PER TAP</span>
        <span class="stat-value" id="stat-cpt">1</span>
      </div>
    </div>
    <div class="top-actions">
      <button class="btn-small" id="music-btn" onclick="toggleMusic()">♪ MUSIC</button>
      <button class="btn-small" onclick="goHome()">⌂ HOME</button>
    </div>
  </div>

  <!-- MAIN -->
  <div id="main">
    <div id="game-area">
      <div id="circle-container">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <div id="main-circle" onclick="handleClick(event)">
          <div class="geo"></div>
        </div>
      </div>
      <div id="float-layer"></div>
    </div>

    <div id="side-panel">
      <div class="panel-header">▸ UPGRADES</div>
      <div id="upgrades-list"></div>
    </div>
  </div>

</div>

<script>
// ─── DATA ────────────────────────────────────────────────
const UPGRADES = [
  { id:'A', name:'Finger Boost',    effect:'+1 CPT',            cpt:1,       cps:0,       cost:25 },
  { id:'B', name:'Auto Tap',        effect:'+1 CPS',            cpt:0,       cps:1,       cost:100 },
  { id:'C', name:'Rapid Clicker',   effect:'+10 CPS',           cpt:0,       cps:10,      cost:700 },
  { id:'D', name:'Turbo Machine',   effect:'+100 CPS',          cpt:0,       cps:100,     cost:6500 },
  { id:'E', name:'Mega Finger',     effect:'+2,000 CPT',        cpt:2000,    cps:0,       cost:150000 },
  { id:'F', name:'Hyper Engine',    effect:'+15,000 CPS',       cpt:0,       cps:15000,   cost:250000 },
  { id:'G', name:'Quantum Reactor', effect:'+5,000,000 CPS',    cpt:0,       cps:5000000, cost:125000000 },
  { id:'H', name:'Infinity Finger', effect:'+2,000,000 CPT',    cpt:2000000, cps:0,       cost:400000000 },
];

// ─── STATE ───────────────────────────────────────────────
let state = { clicks:0, cpt:1, cps:0, counts:{} };
let musicOn = false;
let audioCtx = null;
let musicNodes = [];

// ─── SAVE / LOAD ─────────────────────────────────────────
function saveGame() {
  try { localStorage.setItem('geometryClicker', JSON.stringify(state)); } catch(e) {}
}

function loadGame() {
  try {
    const s = localStorage.getItem('geometryClicker');
    if (s) {
      const d = JSON.parse(s);
      state.clicks = d.clicks || 0;
      state.cpt    = d.cpt    || 1;
      state.cps    = d.cps    || 0;
      state.counts = d.counts || {};
      return true;
    }
  } catch(e) {}
  return false;
}

function hasSave() {
  try {
    const s = localStorage.getItem('geometryClicker');
    return !!s;
  } catch(e) { return false; }
}

// ─── HOME SCREEN ─────────────────────────────────────────
function initHome() {
  const saved = hasSave();
  const contBtn  = document.getElementById('continue-btn');
  const newBtn   = document.getElementById('new-game-btn');
  const saveInfo = document.getElementById('save-info');
  const playBtn  = document.querySelector('.home-btn-primary');

  if (saved) {
    loadGame();
    contBtn.style.display  = 'block';
    newBtn.style.display   = 'block';
    playBtn.style.display  = 'none';
    saveInfo.innerHTML =
      `SAVED PROGRESS<br>` +
      `<span>${fmt(state.clicks)}</span> clicks &nbsp;|&nbsp; ` +
      `<span>${fmt(state.cps)}</span> CPS &nbsp;|&nbsp; ` +
      `<span>${fmt(state.cpt)}</span> CPT`;
  } else {
    contBtn.style.display  = 'none';
    newBtn.style.display   = 'none';
    playBtn.style.display  = 'block';
    saveInfo.textContent   = '';
  }
}

function startGame() {
  // fresh game, no save
  state = { clicks:0, cpt:1, cps:0, counts:{} };
  launchGame();
}

function continueGame() {
  // already loaded in initHome
  launchGame();
}

function newGame() {
  if (!confirm('Start a new game? Your saved progress will be lost.')) return;
  state = { clicks:0, cpt:1, cps:0, counts:{} };
  saveGame();
  launchGame();
}

function launchGame() {
  document.getElementById('home-screen').classList.add('hidden');
  document.getElementById('game-wrapper').classList.add('visible');
  renderUpgrades();
  updateUI();
}

function goHome() {
  saveGame();
  document.getElementById('game-wrapper').classList.remove('visible');
  document.getElementById('home-screen').classList.remove('hidden');
  stopMusic();
  musicOn = false;
  document.getElementById('music-btn').classList.remove('music-on');
  document.getElementById('music-btn').textContent = '♪ MUSIC';
  initHome();
}

// ─── FORMAT ──────────────────────────────────────────────
function fmt(n) {
  if (n >= 1e12) return (n/1e12).toFixed(2) + 'T';
  if (n >= 1e9)  return (n/1e9).toFixed(2)  + 'B';
  if (n >= 1e6)  return (n/1e6).toFixed(2)  + 'M';
  if (n >= 1e3)  return (n/1e3).toFixed(1)  + 'K';
  return Math.floor(n).toString();
}

// ─── CLICK HANDLER ───────────────────────────────────────
function handleClick(e) {
  state.clicks += state.cpt;

  const circle = document.getElementById('main-circle');
  circle.classList.add('clicked');
  setTimeout(() => circle.classList.remove('clicked'), 120);

  spawnParticle(e, '+' + fmt(state.cpt));
  playClick();
  updateUI();
  updateUpgradeBtns();
  saveGame();
}

// ─── PARTICLES ───────────────────────────────────────────
function spawnParticle(e, text) {
  const layer = document.getElementById('float-layer');
  const rect  = layer.getBoundingClientRect();
  const p     = document.createElement('div');
  p.className  = 'particle';
  p.textContent = text;
  p.style.left = (e.clientX - rect.left + (Math.random()*40 - 20)) + 'px';
  p.style.top  = (e.clientY - rect.top  + (Math.random()*20 - 10)) + 'px';
  layer.appendChild(p);
  setTimeout(() => p.remove(), 900);
}

// ─── SOUND ───────────────────────────────────────────────
function initAudio() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
}

function playClick() {
  try {
    initAudio();
    const osc  = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain); gain.connect(audioCtx.destination);
    osc.frequency.setValueAtTime(800, audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(400, audioCtx.currentTime + 0.05);
    gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.08);
    osc.start(); osc.stop(audioCtx.currentTime + 0.08);
  } catch(e) {}
}

function playUpgrade() {
  try {
    initAudio();
    [600, 800, 1000, 1300].forEach((freq, i) => {
      const osc  = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain); gain.connect(audioCtx.destination);
      osc.type = 'sine';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.12, audioCtx.currentTime + i*0.07);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + i*0.07 + 0.15);
      osc.start(audioCtx.currentTime + i*0.07);
      osc.stop(audioCtx.currentTime + i*0.07 + 0.15);
    });
  } catch(e) {}
}

function toggleMusic() {
  musicOn = !musicOn;
  const btn = document.getElementById('music-btn');
  if (musicOn) {
    btn.classList.add('music-on');
    btn.textContent = '♪ ON';
    startMusic();
  } else {
    btn.classList.remove('music-on');
    btn.textContent = '♪ MUSIC';
    stopMusic();
  }
}

function startMusic() {
  try {
    initAudio();
    const notes = [130.81, 164.81, 196, 220, 261.63, 196, 164.81, 130.81];
    let step = 0;
    function playNote() {
      if (!musicOn) return;
      const osc  = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'triangle';
      osc.connect(gain); gain.connect(audioCtx.destination);
      osc.frequency.value = notes[step % notes.length];
      gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.4);
      osc.start(); osc.stop(audioCtx.currentTime + 0.45);
      step++;
      musicNodes.push(setTimeout(playNote, 500));
    }
    playNote();
  } catch(e) {}
}

function stopMusic() {
  musicNodes.forEach(clearTimeout);
  musicNodes = [];
}

// ─── UPGRADES ────────────────────────────────────────────
function buyUpgrade(id) {
  const u = UPGRADES.find(x => x.id === id);
  if (!u || state.clicks < u.cost) return;
  state.clicks -= u.cost;
  state.cpt    += u.cpt;
  state.cps    += u.cps;
  state.counts[id] = (state.counts[id] || 0) + 1;
  playUpgrade();
  saveGame();
  updateUI();
  updateUpgradeBtns();
  const card = document.getElementById('card-' + id);
  if (card) { card.classList.add('just-bought'); setTimeout(() => card.classList.remove('just-bought'), 400); }
  const badge = document.getElementById('count-' + id);
  if (badge) { badge.textContent = 'x' + state.counts[id]; badge.style.opacity = '1'; }
}

function renderUpgrades() {
  const list = document.getElementById('upgrades-list');
  list.innerHTML = '';
  UPGRADES.forEach(u => {
    const affordable = state.clicks >= u.cost;
    const count = state.counts[u.id] || 0;
    const card  = document.createElement('div');
    card.className = 'upgrade-card' + (affordable ? ' affordable' : '');
    card.id = 'card-' + u.id;
    card.innerHTML = `
      <div class="upgrade-top">
        <div class="upgrade-badge">${u.id}</div>
        <div class="upgrade-name">${u.name}</div>
        <div class="upgrade-count" id="count-${u.id}" style="opacity:${count>0?1:0}">x${count}</div>
      </div>
      <div class="upgrade-effect">${u.effect}</div>
      <div class="upgrade-bottom">
        <div class="upgrade-cost ${affordable?'can-afford':''}" id="cost-${u.id}">◈ ${fmt(u.cost)}</div>
        <button class="buy-btn ${affordable?'enabled':''}" id="btn-${u.id}"
          onclick="buyUpgrade('${u.id}')" ${affordable?'':'disabled'}>BUY</button>
      </div>
    `;
    list.appendChild(card);
  });
}

function updateUpgradeBtns() {
  UPGRADES.forEach(u => {
    const affordable = state.clicks >= u.cost;
    const card = document.getElementById('card-' + u.id);
    const btn  = document.getElementById('btn-'  + u.id);
    const cost = document.getElementById('cost-' + u.id);
    const cnt  = document.getElementById('count-'+ u.id);
    if (!card) return;
    card.classList.toggle('affordable', affordable);
    btn.classList.toggle('enabled', affordable);
    btn.disabled = !affordable;
    cost.classList.toggle('can-afford', affordable);
    const c = state.counts[u.id] || 0;
    cnt.textContent  = 'x' + c;
    cnt.style.opacity = c > 0 ? '1' : '0';
  });
}

// ─── UI UPDATE ───────────────────────────────────────────
let prevClicks = 0;
function updateUI() {
  document.getElementById('stat-clicks').textContent = fmt(state.clicks);
  document.getElementById('stat-cps').textContent    = fmt(state.cps);
  document.getElementById('stat-cpt').textContent    = fmt(state.cpt);
  if (state.clicks !== prevClicks) {
    const el = document.getElementById('stat-clicks');
    el.classList.remove('bump');
    void el.offsetWidth;
    el.classList.add('bump');
    setTimeout(() => el.classList.remove('bump'), 150);
    prevClicks = state.clicks;
  }
}

// ─── AUTO CLICKER ────────────────────────────────────────
let lastTick = Date.now();
function tick() {
  const now = Date.now();
  const dt  = (now - lastTick) / 1000;
  lastTick  = now;
  if (state.cps > 0 && document.getElementById('game-wrapper').classList.contains('visible')) {
    state.clicks += state.cps * dt;
    updateUI();
    updateUpgradeBtns();
  }
  requestAnimationFrame(tick);
}

// ─── INIT ────────────────────────────────────────────────
initHome();
requestAnimationFrame(tick);
setInterval(saveGame, 10000);
</script>
